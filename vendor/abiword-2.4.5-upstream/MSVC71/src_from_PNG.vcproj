			RelativePath="..\abi\src\wp\ap\xp\sidebar.png">
			<FileConfiguration
				Name="Debug|Win32">
				<Tool
					Name="VCCustomBuildTool"
					Description="Creating src file from $(InputPath)"
					CommandLine="..\abi\src\MSVC71_Debug\bin\cdump.exe &quot;$(InputPath)&quot; g_pngSidebar &gt; .\ap_wp_sidebar.cpp"
