			</FileConfiguration>
			<FileConfiguration
				Name="Release|Win32">
				<Tool
					Name="VCCustomBuildTool"
					Description="Creating src file from $(InputPath)"
					CommandLine="..\abi\src\MSVC71_Release\bin\cdump.exe &quot;$(InputPath)&quot; g_pngSidebar &gt; ./ap_wp_sidebar.cpp"
