plugindir = @ABI_PLUGIN_DIR@

INCLUDES = -I'$(top_srcdir)/tools/abimathview/itex2MML' $(AF_INCLUDES) $(ICONV_INCLUDES) $(WP_INCLUDES)  $(OTHER_INCLUDES) $(MATHVIEW_CFLAGS) $(TEXT_INCLUDES) 
 
CPPFLAGS = @ABI_CPPFLAGS@ @CPPFLAGS@ @PLATFORM_CPPFLAGS@

LDFLAGS = @LDFLAGS@ @MATHVIEW_LIBS@ @PLATFORM_LDFLAGS@

plugin_LTLIBRARIES = libAbiMathView.la

libAbiMathView_la_SOURCES = AbiMathView.cpp  \
	gr_Abi_CharArea.cpp \
	gr_Abi_ColorArea.cpp \
	gr_Abi_DefaultShaper.cpp \
	gr_Abi_StandardSymbolsShaper.cpp \
	gr_Abi_ComputerModernShaper.cpp \
	gr_Abi_InkArea.cpp \
	gr_Abi_MathGraphicDevice.cpp \
	gr_Abi_RenderingContext.cpp \
	ie_imp_MathML.cpp 

libAbiMathView_la_LIBADD = ../itex2MML/libitex2MML.la @ABI_LIBS@

libAbiMathView_la_LDFLAGS = -no-undefined -module -avoid-version
